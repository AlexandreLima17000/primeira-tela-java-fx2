   <center>
      <BorderPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <center>
            <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #FFFFFF;" BorderPane.alignment="CENTER">
               <children>
                  <TextField fx:id="campoUsuario" promptText="NOME" style="-fx-background-color: #000000;">
                     <VBox.margin>
                        <Insets left="15.0" right="15.0" top="100.0" />
                     </VBox.margin>
                     <font>
                        <Font name="System Bold" size="12.0" />
                     </font>
                  </TextField>
                  <Line endX="100.0" startX="-275.0">
                     <VBox.margin>
                        <Insets left="15.0" right="15.0" />
                     </VBox.margin>
                  </Line>
                  <PasswordField fx:id="campoSenha" promptText="SENHA" style="-fx-background-color: FFFFFF;">
                     <VBox.margin>
                        <Insets left="15.0" right="15.0" top="15.0" />
                     </VBox.margin>
                  </PasswordField>
                  <Line endX="100.0" layoutX="301.0" layoutY="136.0" startX="-275.0">
                     <VBox.margin>
                        <Insets left="15.0" />
                     </VBox.margin>
                  </Line>
                  <PasswordField fx:id="campoConfimarSenha" promptText="CONFIRMAR SENHA" style="-fx-background-color: FFFFFF;">
                     <VBox.margin>
                        <Insets left="15.0" right="15.0" top="15.0" />
                     </VBox.margin>
                  </PasswordField>
                  <Line endX="100.0" startX="-275.0">
                     <VBox.margin>
                        <Insets left="15.0" right="15.0" />
                     </VBox.margin>
                  </Line>
                  <Button fx:id="btnVoltar" mnemonicParsing="false" onAction="#onVoltarClick" text="VOLTA">
