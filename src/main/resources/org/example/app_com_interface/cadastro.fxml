                        <Insets left="50.0" top="30.0" />
                     </VBox.margin></Button>
                  <Button fx:id="btnCriarConta" mnemonicParsing="false" onAction="#onCadastrarClick" text="CRIAR CONTA">
                     <VBox.margin>
                        <Insets bottom="30.0" left="200.0" right="50.0" top="-25.0" />
                     </VBox.margin>
                  </Button>
               </children>
            </VBox>
         </center>
      </BorderPane>
   </center>
